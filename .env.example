# MAGMA Memory Engine Configuration
# Copy this file to .env and fill in your values

# ── LLM Backend (for Slow Path causal/entity inference) ──
# Required: Your API key for the LLM provider of your choice
# OpenAI-compatible endpoint pattern:
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── Optional: Obsidian Vault Integration ──
# Path to your Obsidian vault (for wiki-ingest, review-queue, graph-export scripts)
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# ── Optional: HuggingFace Cache ──
# Set to 1 if HF is unreachable (e.g. behind firewall) — uses cached models only
HF_HUB_OFFLINE=0
